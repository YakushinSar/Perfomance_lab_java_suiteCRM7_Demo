<?xml version="1.0" encoding="UTF-8"?>
<Configuration
        xmlns="https://logging.apache.org/xml/ns"
>

    <Appenders>
        <!-- Вывод в консоль -->
        <Console name="CONSOLE">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- Вывод в файл -->
        <File name="FILE" fileName="target/logs/tests.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %c - %msg%n"/>
        </File>
    </Appenders>

    <Loggers>
        <!-- Логгер для всего проекта -->
        <Logger name="homework3" level="INFO" additivity="false">
            <AppenderRef ref="CONSOLE"/>
            <AppenderRef ref="FILE"/>
        </Logger>

        <!-- Корневой логгер (для всех остальных) -->
        <Root level="INFO">
            <AppenderRef ref="CONSOLE"/>
        </Root>
    </Loggers>
</Configuration>